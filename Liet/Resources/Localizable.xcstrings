    "Stretch fills the canvas exactly. Contain keeps the whole image inside the canvas. Crop fills the canvas by trimming from the center." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stretch fills the canvas exactly. Contain keeps the whole image inside the canvas. Crop fills the canvas by trimming from the center."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "引き伸ばしではキャンバスをぴったり埋めます。全体表示では画像全体をキャンバス内に収めます。中央クロップでは中央を基準に切り抜いてキャンバスを埋めます。"
          }
        }
      }
    },
    "Successful outputs are ready even if some images failed. You can save only the new processed files from here." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Successful outputs are ready even if some images failed. You can save only the new processed files from here."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一部の画像が失敗しても、成功した出力は保存できます。ここから新しく処理したファイルだけを保存できます。"
          }
        }
      }
    },
    "Use Files to choose a folder in the Files app. Use Photos to add the processed images to your photo library as new items." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use Files to choose a folder in the Files app. Use Photos to add the processed images to your photo library as new items."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「ファイル」を使うと、ファイルアプリ内のフォルダを選べます。「写真」を使うと、処理後の画像を新しい項目として写真ライブラリに追加できます。"
          }
        }
      }
    },
    "When the settings look right, run one batch. Liet creates new files and never overwrites the originals." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When the settings look right, run one batch. Liet creates new files and never overwrites the originals."
